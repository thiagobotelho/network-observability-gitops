# Namespace onde o Network Observability e o LokiStack dedicado serão criados.
NETOBSERV_NAMESPACE=netobserv

# Secret S3 consumido pelo LokiStack dedicado do NetObserv.
NETOBSERV_LOKI_SECRET=netobserv-loki-s3
NETOBSERV_LOKI_BUCKET=netobserv

# MinIO local criado pelo loki-gitops para laboratório CRC.
MINIO_NAMESPACE=openshift-logging
MINIO_SECRET_NAME=minio-credentials
MINIO_SERVICE_HOST=minio.openshift-logging.svc
MINIO_SERVICE_PORT=9000
MINIO_REGION=us-east-1

# Imagem usada apenas pelo Job idempotente que garante o bucket.
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z
